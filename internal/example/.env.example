# Example configuration for the pgoutbox example command.
# Copy to .env and fill in your own values; .env is git-ignored.
#
# All variables are optional. When unset, the example falls back to the
# localhost defaults in config.go.

# Postgres connection string.
PGOUTBOX_DSN=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable

# Comma-separated list of Kafka brokers.
PGOUTBOX_BROKERS=localhost:9092

# Set to any non-empty value to log every SQL statement.
PGOUTBOX_TRACE=

# Set to any non-empty value to run the enqueue benchmark instead of the relay.
# The benchmark compares serial, batched, and concurrent enqueue throughput.
PGOUTBOX_BENCH=

# Total events enqueued per pattern (default 10000).
PGOUTBOX_BENCH_TOTAL=

# Events per transaction in the batched pattern (default 100).
PGOUTBOX_BENCH_BATCH=

# Goroutines in the concurrent pattern (default 16).
PGOUTBOX_BENCH_CONC=
